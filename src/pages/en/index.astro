---
import Layout from "../../layouts/Layout.astro";
import Badge from "../../components/Badge.astro";
import Experience from "../../components/Experience.astro";
import SectionContainer from "../../components/SectionContainer.astro";
import Academy from "../../components/Icons/academy.astro";
import Projects from "../../components/Projects.astro";
import Code from "../../components/Icons/Code.astro";
import AboutMe from "../../components/AboutMe.astro";
import User from "../../components/Icons/User.astro";
import Contact from "../../components/Contacto.astro";
import Socialmedia from "../../components/Socialmedia.astro";
import { getLangFromUrl, useTranslations } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={t("title")} {lang} description={t("badge")}>
  <main class="px-4">
    <SectionContainer class="py-44 pb-20">
      <img
        class="rounded-full size-12 mb-4"
        src="https://avatars.githubusercontent.com/u/64212933?v=4"
        alt="Danilo Caceres"
      />
      <h1
        class="text-gray-900 dark:text-white text-3xl md:text-4xl lg:text-5xl font-bold flex flex-row gap-x-4 pb-6 lg:pb-10 text-center"
      >
        {t("title")} <a
          href="https://www.linkedin.com/in/danilo-caceres/"
          target="_blank"
          rel="noopener"
          class="flex justify-center items-center py-4 hover:scale-105"
        >
          <Badge>{t("badge")}</Badge></a
        >
      </h1>
      <h2 class="text-2xl lg:text-2xl text-wrap max-w-[500px]">
        <span>{t("presentacion")}</span>
      </h2>
      <nav class="flex gap-4 mt-8 flex-wrap">
        <SectionContainer>
          <Socialmedia />
        </SectionContainer>

        <SectionContainer id="experiencia">
          <h2
            class="text-2xl font-semibold mb-6 flex gap-x-2 items-center pt-10"
          >
            <Academy class="size-6" />
            {t("experiencia")}
          </h2>
          <Experience />
        </SectionContainer>

        <SectionContainer id="proyectos">
          <h2
            class="text-2xl font-semibold mb-6 flex gap-x-2 items-center pt-10"
          >
            <Code class="size-7" />
            {t("priject")}
          </h2>
          <Projects />
        </SectionContainer>

        <SectionContainer id="sobre-mi">
          <h2
            class="text-2xl font-semibold mb-6 flex gap-x-2 items-center pt-10"
          >
            <User class="size-7" />
            {t("mi1")}
          </h2>
          <AboutMe />
        </SectionContainer>

        <SectionContainer id="contacto">
          <Contact />
        </SectionContainer>
      </nav>
    </SectionContainer>
  </main>
</Layout>
