---
const { link } = Astro.props;
---

    <a
    href={link} target="_blank"
    class="bg-black/5
    border
    border-black/10
    dark:bg-white/5
    dark:border-white/10
    rounded-full
    inline-flex
    justify-center
    items-center
    gap-x-2
    py-1
    px-2
    md:px-4
    md:py-2
    text-xs
    md:text-base
    transition
    hover:scale-110
    hover:bg-black/10
    dark:hover:bg-white/10 " {...Astro.props}>
    <slot />
    </a> 

